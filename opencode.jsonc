{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.3-codex",
  "small_model": "opencode/deepseek-v4-flash-free",
  "lsp": true,
  "plugin": ["opencode-beads", "@slkiser/opencode-quota"],
  "command": {
    "goal": {
      "description": "Set, show, or clear the current session goal",
      "template": "$ARGUMENTS"
    }
  },
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": "allow",
    "task": "allow",
    "external_directory": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "skill": "allow",
    "question": "allow",
    "lsp": "allow"
  },
  "watcher": {
    "ignore": ["node_modules/**", ".git/**", ".beads/**", ".turbo/**", "dist/**"]
  },
  "agent": {
    "code-review": {
      "description": "Reviews code for bugs, security issues, and best practices using deepseek-v4-flash-free",
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "temperature": 0.1,
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "edit": "deny",
        "bash": "deny"
      },
      "prompt": "{file:./.opencode/prompts/code-review.txt}"
    }
  },
  "instructions": [
    "CLAUDE.md",
    "README.md",
    "docs/acceptance-checklist.md",
    "docs/deployment-design.md",
    "docs/logging.md",
    "docs/unifi-logging.md"
  ]
}
