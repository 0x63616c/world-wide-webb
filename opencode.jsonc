{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "plugin": ["opencode-beads", "@slkiser/opencode-quota"],
  "command": {
    "goal": {
      "description": "Set, show, or clear the current session goal",
      "template": "$ARGUMENTS"
    },
    "recap": {
      "description": "Recap the current conversation; pass 'full' for the entire session",
      "template": "Use the recap skill to recap this conversation. Arguments: $ARGUMENTS"
    },
    "commit-and-push": {
      "description": "Commit the current work and push the branch",
      "template": "Use the commit-and-push skill to commit and push the current work. Arguments: $ARGUMENTS"
    },
    "remember": {
      "description": "Save a durable memory globally by default, or locally with --local",
      "template": "Use the remember skill to save a durable memory. Arguments: $ARGUMENTS"
    },
    "ticket": {
      "description": "Create or update Beads tickets through the canonical writing-tickets workflow",
      "template": "Use the writing-tickets skill to create or update Beads tickets immediately. Arguments: $ARGUMENTS"
    }
  },
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": "allow",
    "task": "allow",
    "external_directory": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "skill": "allow",
    "question": "allow",
    "lsp": "allow"
  },
  "watcher": {
    "ignore": ["node_modules/**", ".git/**", ".beads/**", ".turbo/**", "dist/**"]
  },
  "agent": {
    "code-review": {
      "description": "Reviews code for bugs, security issues, and best practices using deepseek-v4-flash-free",
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "temperature": 0.1,
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "skill": "allow",
        "edit": "deny",
        "bash": "deny"
      },
      "prompt": "{file:./.opencode/prompts/code-review.txt}"
    }
  },
  "instructions": [
    "CLAUDE.md",
    "README.md",
    "docs/acceptance-checklist.md",
    "docs/deployment-design.md",
    "docs/logging.md",
    "docs/unifi-logging.md"
  ]
}
