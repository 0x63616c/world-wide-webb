{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.4-mini",
  "lsp": true,
  "plugin": ["opencode-beads", "@slkiser/opencode-quota"],
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": "allow",
    "task": "allow",
    "external_directory": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "skill": "allow",
    "question": "allow",
    "lsp": "allow"
  },
  "watcher": {
    "ignore": ["node_modules/**", ".git/**", ".beads/**", ".turbo/**", "dist/**"]
  },
  "instructions": [
    "CLAUDE.md",
    "README.md",
    "docs/acceptance-checklist.md",
    "docs/deployment-design.md",
    "docs/logging.md",
    "docs/unifi-logging.md"
  ]
}
