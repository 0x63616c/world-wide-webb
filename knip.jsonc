{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  // Dead-code detector (www-k6p1). `bun run knip` runs in lefthook pre-push and
  // CI for unused files, dependencies, exports and types. Export-level detection
  // used to be disabled because Temporal exported activities/workflows by runtime
  // name; Temporal left with products/project-management, so it is on now.
  //
  // An export that is deliberately part of a public surface with no internal
  // consumer yet (the shared tile-author UI primitives, infra component props)
  // is annotated `@public` and excluded via "tags" below, so the annotation is
  // load-bearing rather than decorative.
  //
  // Most entry points are auto-detected from each workspace's package `exports`,
  // `bin`, and the vite/storybook/vitest plugins. We only declare the edges knip
  // can't see: Docker CMD/ENTRYPOINT targets and db scripts.

  // Exports tagged `@public` are a deliberate surface, not dead code.
  "tags": ["-public"],

  "ignore": [
    // Codegen output (Track C Q5): `bun run apps:gen` emits these from the tile
    // registry as a byte-identical validation artifact. Nothing imports them yet
    // (Slice 5 flips runtime consumers), and generated files are opaque to the
    // dead-code detector just as they are to biome (`.gen.ts` is ignored there too).
    "features/_generated/**",
    ".claude/**", // Workflow-tool scripts (run by the Workflow tool, never imported)
    ".opencode/**", // OpenCode plugins (loaded at runtime by the opencode host, never imported)
    "docs/media-tiles/**", // Design handoff bundle (prototypes/reference, not app code)
    "docs/captive-portal/design/**", // Captive portal design handoff (reference, not app code)
    "**/ios/**/public/**" // Capacitor web-bundle copies synced into iOS project (not source)
  ],

  // Real runtime deps with no JS-visible import edge.
  "ignoreDependencies": [
    // Capacitor plugins loaded by the native iOS runtime via `cap sync`,
    // declared in capacitor.config.ts / Package.swift, never `import`ed in TS.
    // (@capacitor/core and screen-brightness are now imported directly, so knip
    // sees those edges itself and they no longer need ignore entries.)
    "@capacitor/ios",
    "@capacitor/status-bar",
    // Loaded on demand by `vitest run --coverage` (ad-hoc local runs only; CI
    // never passes --coverage), per the `coverage.provider` in vitest.config.ts.
    // It's invoked by the vitest CLI, not imported, so knip can't see the edge -
    // kept declared where coverage runs (www-k6p1).
    "@vitest/coverage-v8",
    // bdui is the beads viewer CLI (the `bv` tool, config under .bv/); run from the
    // shell, never imported, so knip sees no edge (www-iy13).
    "bdui",
    // quality-gate.ts launches Biome through bunx so every workflow/hook uses the
    // same command path, but knip cannot see stringly CLI edges.
    "@biomejs/biome",
    // Folded features (Track C) have no package.json of their own — they're
    // thin App folders, not workspace packages (AGENTS.md) — so knip resolves
    // their files against the root workspace, which doesn't declare apps/web's
    // frontend test deps. These ARE real, used-in-apps/web deps (via
    // web.test.tsx / web-view.test.tsx render calls); the edge is just
    // invisible across this workspace-boundary quirk until a generic fix for
    // the migration lands (Track C, see W0). Storybook stories/story-tests stay
    // under apps/web/src (same precedent as guest-wifi), so they don't need
    // this treatment. maplibre-gl (features/tesla/tesla-map.tsx) is the same
    // workspace-boundary quirk — a real apps/web dep the feature folder can't
    // see resolved against.
    "@testing-library/jest-dom",
    "@testing-library/react",
    "maplibre-gl"
  ],

  // `tilt` is the dev-stack binary invoked by the root `dev` script; not an npm dep.
  // `security` is the macOS Keychain CLI used by vault.ts + migrate-1p-to-sops.ts to
  // retrieve the age private key at runtime; not an npm dep (CC-k8t7).
  // `kubectl` is spawned by the infra ghcr-pull-secret preflight to read live
  // Secrets during `pulumi up`; a system binary on the deploy runner, not an npm dep.
  // `openssl` is spawned by the guest-server TLS test to generate a throwaway
  // self-signed cert at run time (never committed, see guest-server.test.ts);
  // a system binary on macOS/CI Linux images, not an npm dep.
  "ignoreBinaries": ["tilt", "scripts/check-rename-identity.py", "security", "kubectl", "openssl"],

  "workspaces": {
    ".": {
      // scripts/*.ts are standalone one-time Bun scripts (OAuth flows, save scripts)
      // invoked directly by their companion .sh wrappers, never imported.
      // scripts/*.mjs are standalone node CLIs (verify-wall-panel.mjs, run by the
      // operator/CI) + their hermetic node tests (test-*.mjs); panel-health.mjs is
      // imported by both, so its exports are reached from these entries (www-jtp0.7).
      // app-kit/{index,server}.ts are the web-safe and server barrels of the
      // codegen authoring surface (Task 3.1): no feature imports them yet
      // (features + the codegen collector land in later Track C tasks), so they
      // need an explicit entry until then.
      "entry": ["scripts/*.ts", "scripts/*.mjs", "app-kit/index.ts", "app-kit/server.ts"]
    },
    "apps/api": {
      // server.ts = Docker CMD; purge.ts = the portal data-hygiene cronJob
      // entrypoint, bundled into the api image + run via command override
      // (www-q002.18); cron-run.ts = the generic S2 cron dispatcher, same
      // treatment (bundled to cron.js, run via `bun cron.js <name>`);
      // seed.ts = db:seed script.
      // drizzle.config.ts + the exports map (., ./trpc, ./worker) are
      // auto-detected.
      "entry": ["src/server.ts", "src/purge.ts", "src/cron-run.ts", "src/db/seed.ts"]
    },
    "infra": {
      // program.ts = the Pulumi program (Pulumi.yaml `main`, run by the pulumi
      // CLI, never imported). src/index.ts (the vocabulary barrel) is
      // auto-detected from `main`. Tests live in test/. @pulumi/* ARE imported
      // (component.ts), so no ignoreDependencies needed.
      "entry": ["program.ts", "test/**/*.test.ts"]
    },
    "infra/unifi": {
      // Separate Pulumi project (control-center-unifi, www-j934.3): program.ts is
      // auto-detected as the entry from Pulumi.yaml `main`; src/unifi.ts exports
      // are consumed by it + the test. @pulumiverse/unifi + @pulumi/pulumi are
      // imported, so no ignoreDependencies needed. scripts/*.ts are standalone
      // Bun CLIs run by hand (gen-fixed-ip-manifest.ts re-derives the off-repo
      // manifest from the live controller; www-j934.3.1), never imported.
      "entry": ["scripts/*.ts", "test/**/*.test.ts"]
    },
    "infra/cloudflare": {
      // Separate Pulumi PROJECT (control-center-cloudflare) for the adopt-only CF
      // edge state (www-j934.2). program.ts (the Pulumi program) is auto-detected
      // from package `main`; src/{access,routes}.ts are imported by it; tests in
      // test/.
      "entry": ["test/**/*.test.ts"]
    },
    "drizzle": {
      // load-secret.js is the drizzle image's `bun --preload` ENTRYPOINT.
      "entry": ["load-secret.js"]
    },
    "packages/logger": {
      // src/index.ts is auto-detected from the `exports` map.
      // Tests are in test/ - declare explicitly so knip registers them as entries.
      "entry": ["test/**/*.test.ts"]
    },
    "packages/platform": {
      // src/index.ts is auto-detected from the `exports` map.
      // Tests are in test/ - declare explicitly so knip registers them as entries.
      "entry": ["test/**/*.test.ts"]
    },
    "packages/worker-runtime": {
      // src/index.ts is auto-detected from the `exports` map.
      // Tests are in test/ - declare explicitly so knip registers them as entries.
      "entry": ["test/**/*.test.ts"]
    },
    "apps/web": {
      // Guest portal entry (vite.portal.config.ts -> portal.html -> this file)
      // is a second build knip's vite-plugin auto-detection doesn't see (it
      // only picks up the default vite.config.ts / index.html pair).
      // e2e-portal/playwright.config.ts: knip's Playwright plugin only
      // auto-detects a config at the package root; ours lives in a
      // subdirectory, so it isn't found without an explicit entry.
      "entry": ["src/portal/main.tsx", "e2e-portal/playwright.config.ts"]
    }
  }
}
