{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  // Dead-code detector (www-k6p1). ZERO-TOLERANCE: knip runs in the lefthook
  // pre-push hook and CI `test` job and exits non-zero on ANY unused file /
  // export / dep, so the repo is mechanically held at zero dead code.
  // `bun run knip` to inspect, `bun run knip:fix` to auto-remove. Intentional
  // public API with no internal consumer yet is kept via a JSDoc tag —
  // `/** @public — <reason> */` above the export (knip honours @public).
  //
  // Most entry points are auto-detected from each workspace's package `exports`,
  // `bin`, and the vite/storybook/vitest plugins. We only declare the edges knip
  // can't see: Docker CMD/ENTRYPOINT targets and db scripts.

  "ignore": [
    ".claude/**", // Workflow-tool scripts (run by the Workflow tool, never imported)
    "experiments/**", // Throwaway spikes
    "docs/media-tiles/**" // Design handoff bundle (prototypes/reference, not app code)
  ],

  // Real runtime deps with no JS-visible import edge.
  "ignoreDependencies": [
    // Capacitor plugins are loaded by the native iOS runtime via `cap sync`,
    // declared in capacitor.config.ts / Package.swift, never `import`ed in TS.
    "@capacitor/core",
    "@capacitor/ios",
    "@capacitor/haptics",
    "@capacitor/status-bar",
    "@capacitor-community/screen-brightness",
    // coverage.sh runs `cd apps/web && vitest run --coverage`, so the v8 provider
    // must resolve from apps/web. It's invoked by the vitest CLI, not imported, so
    // knip can't see the edge — kept declared where coverage runs (www-k6p1).
    "@vitest/coverage-v8"
  ],

  // `tilt` is the dev-stack binary invoked by the root `dev` script; not an npm dep.
  "ignoreBinaries": ["tilt"],

  "workspaces": {
    ".": {
      // load-secret.js is the drizzle image's `bun --preload` ENTRYPOINT.
      "entry": ["deploy.config.ts", "apps/drizzle/load-secret.js"]
    },
    "apps/api": {
      // server.ts = Docker CMD; seed.ts = db:seed script. drizzle.config.ts +
      // the exports map (., ./trpc, ./worker) are auto-detected.
      "entry": ["src/server.ts", "src/db/seed.ts"]
    },
    "packages/bosun": {
      // serve.ts = the deployed agent (Docker CMD); cli.ts = the root `bosun`
      // script target (no package `bin`). Tests live in test/, not src/.
      "entry": ["src/serve.ts", "src/cli.ts", "test/**/*.test.ts"]
    }
  }
}
