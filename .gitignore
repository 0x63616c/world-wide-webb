# Dependencies
node_modules/

# Build output
dist/
build/

# Postgres migration artifacts (Swarm->CNPG dump + count tsvs, www-j934.8).
# The dump is the rollback copy held OFF any pgdata volume; never committed.
.pg-migration/

# Environment
.env
.env.*
!.env.example

# Database
*.db
*.db-journal
*.db-wal
*.db-shm

# Tilt
.tilt/

# Vite
.vite/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
*.swp
*.swo

# Claude Code
.claude/settings.local.json

# OpenCode local quota state
opencode-quota/

# Test coverage
coverage/
.vitest-reports/

# TypeScript build cache
*.tsbuildinfo

# Beads / Dolt files (added by bd init)
.dolt/
.beads-credential-key

# Tesla map basemap tiles — large, host locally / on homelab (see www-gma)
apps/web/public/maps/*.pmtiles

# Storybook
*storybook.log
storybook-static

# ship workflow scratch + build worktrees
.claude/worktrees/
.claire/

# Runtime scheduler lock — ephemeral, never commit
.claude/scheduled_tasks.lock

# beads `--shared` hook dir — beads' hook lifecycle is owned by lefthook, NOT
# beads (www-sg4p). This dir only appears if someone runs `bd hooks install
# --shared`, which hijacks core.hooksPath; never commit it. Don't run that.
.beads-hooks/

# cmux local workspace state
.cmux/

# PR/verification screenshots — kept on local disk for reference, never tracked
# (referenced nowhere in docs/code; purged from history in www-st5j to keep the
# public repo lean). Drop new verification shots here freely; git ignores them.
docs/screenshots/
