{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "suspicious": {
        "noExplicitAny": "error",
        "noConsole": {
          "level": "error",
          "options": { "allow": ["error", "warn"] }
        },
        "noFocusedTests": "error"
      },
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error"
      },
      "style": {
        "useImportType": "error",
        "useExportType": "error",
        "noNonNullAssertion": "error",
        "useThrowOnlyError": "error",
        "noEnum": "error",
        "noProcessEnv": "error"
      },
      "complexity": {
        "noBannedTypes": "error"
      }
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/storybook-static",
      "!**/*.gen.ts",
      "!**/.tilt",
      "!**/.beads",
      "!.worktrees",
      "!**/coverage",
      "!**/.claude",
      "!**/.cmux",
      "!**/experiments",
      "!**/docs/media-tiles",
      "!**/docs/captive-portal/design",
      "!**/products/project-management/public",
      "!**/DerivedData",
      "!**/ios/App/App/public/assets"
    ]
  },
  "overrides": [
    {
      "includes": [
        "**/products/control-center/api/src/env.ts",
        "**/products/control-center/api/drizzle.config.ts",
        "**/products/control-center/web/vite.config.ts",
        "**/products/captive-portal/apps/frontend/playwright.config.ts",
        "**/products/captive-portal/apps/frontend/e2e/**",
        "**/scripts/**"
      ],
      "linter": { "rules": { "style": { "noProcessEnv": "off" } } }
    },
    {
      "includes": ["**/scripts/**"],
      "linter": { "rules": { "suspicious": { "noConsole": "off" } } }
    },
    {
      "includes": ["**/packages/logger/src/**"],
      "linter": { "rules": { "style": { "noProcessEnv": "off" } } }
    },
    {
      "includes": ["**/products/project-management/server.ts"],
      "linter": { "rules": { "style": { "noProcessEnv": "off" } } }
    },
    {
      "includes": ["**/infra/unifi/program.ts", "**/infra/unifi/src/**"],
      "linter": { "rules": { "style": { "noProcessEnv": "off" } } }
    },
    {
      "includes": [
        "**/products/text-your-ex/apps/api/src/env.ts",
        "**/products/text-your-ex/apps/api/src/db/index.ts",
        "**/products/text-your-ex/apps/api/src/index.ts",
        "**/products/text-your-ex/apps/api/src/seed.ts"
      ],
      "linter": { "rules": { "style": { "noProcessEnv": "off" } } }
    },
    {
      "includes": [
        "**/products/text-your-ex/apps/api/src/__tests__/**",
        "**/products/text-your-ex/apps/e2e/**"
      ],
      "linter": {
        "rules": {
          "style": { "noProcessEnv": "off", "noNonNullAssertion": "off" }
        }
      }
    },
    {
      "includes": ["**/products/text-your-ex/docs/design-reference/**"],
      "linter": {
        "rules": {
          "a11y": {
            "useButtonType": "off",
            "noSvgWithoutTitle": "off",
            "useKeyWithClickEvents": "off",
            "noStaticElementInteractions": "off",
            "useSemanticElements": "off"
          },
          "suspicious": { "noArrayIndexKey": "off", "noConsole": "off" },
          "style": { "noNonNullAssertion": "off", "useTemplate": "off" },
          "complexity": { "useLiteralKeys": "off" },
          "correctness": { "noUnusedVariables": "off", "noUnusedImports": "off" }
        }
      }
    }
  ]
}
