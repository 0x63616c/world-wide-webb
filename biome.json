{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "error",
        "noConsole": {
          "level": "error",
          "options": { "allow": ["error", "warn"] }
        },
        "noFocusedTests": "error"
      },
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error"
      },
      "style": {
        "useImportType": "error",
        "useExportType": "error",
        "noNonNullAssertion": "error",
        "useThrowOnlyError": "error",
        "noEnum": "error",
        "noProcessEnv": "error"
      },
      "complexity": {
        "noBannedTypes": "error"
      }
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/storybook-static",
      "!**/*.gen.ts",
      "!**/.tilt",
      "!**/.beads",
      "!**/coverage",
      "!**/.claude",
      "!**/.cmux",
      "!**/experiments",
      "!**/docs/media-tiles",
      "!**/docs/captive-portal/design"
    ]
  },
  "overrides": [
    {
      "includes": [
        "**/apps/api/src/env.ts",
        "**/apps/api/drizzle.config.ts",
        "**/apps/web/vite.config.ts",
        "**/products/captive-portal/apps/frontend/playwright.config.ts",
        "**/products/captive-portal/apps/frontend/e2e/**",
        "**/scripts/**"
      ],
      "linter": { "rules": { "style": { "noProcessEnv": "off" } } }
    },
    {
      "includes": ["**/scripts/**"],
      "linter": { "rules": { "suspicious": { "noConsole": "off" } } }
    },
    {
      "includes": ["**/packages/logger/src/**"],
      "linter": { "rules": { "style": { "noProcessEnv": "off" } } }
    },
    {
      "includes": ["**/infra/unifi/program.ts", "**/infra/unifi/src/**"],
      "linter": { "rules": { "style": { "noProcessEnv": "off" } } }
    }
  ]
}
