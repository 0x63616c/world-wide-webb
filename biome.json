{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "suspicious": {
        "noExplicitAny": "error",
        "noConsole": {
          "level": "error",
          "options": { "allow": ["error", "warn"] }
        },
        "noFocusedTests": "error"
      },
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error"
      },
      "style": {
        "useImportType": "error",
        "useExportType": "error",
        "noNonNullAssertion": "error",
        "useThrowOnlyError": "error",
        "noEnum": "error",
        "noProcessEnv": "error",
        "noRestrictedGlobals": {
          "level": "error",
          "options": {
            "deniedGlobals": {
              "AudioContext": "Play sound through the panel's sound bus: playCue() from lib/sound. It owns the one AudioContext, the cue library, and the choice between iOS's own recordings and synthesis.",
              "webkitAudioContext": "Play sound through the panel's sound bus: playCue() from lib/sound.",
              "Audio": "Play sound through the panel's sound bus: playCue() from lib/sound. Bundling an audio element also means an asset and a licence to honour."
            }
          }
        }
      },
      "complexity": {
        "noBannedTypes": "error"
      }
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/storybook-static",
      "!**/*.gen.ts",
      "!**/.tilt",
      "!.worktrees",
      "!**/coverage",
      "!**/.claude",
      "!**/.superpowers",
      "!**/.cmux",
      "!**/experiments",
      "!**/docs/media-tiles",
      "!**/docs/captive-portal/design",
      "!**/DerivedData",
      "!**/ios/App/App/public",
      "!**/ios/App/App/capacitor.config.json"
    ]
  },
  "overrides": [
    {
      "includes": [
        "**/products/control-center/api/src/env.ts",
        "**/products/control-center/api/drizzle.config.ts",
        "**/products/control-center/web/vite.config.ts",
        "**/products/captive-portal/apps/frontend/playwright.config.ts",
        "**/products/captive-portal/apps/frontend/e2e/**",
        "**/scripts/**"
      ],
      "linter": { "rules": { "style": { "noProcessEnv": "off" } } }
    },
    {
      "includes": ["**/scripts/**"],
      "linter": { "rules": { "suspicious": { "noConsole": "off" } } }
    },
    {
      "includes": ["**/packages/logger/src/**"],
      "linter": { "rules": { "style": { "noProcessEnv": "off" } } }
    },
    {
      "includes": ["**/infra/unifi/program.ts", "**/infra/unifi/src/**"],
      "linter": { "rules": { "style": { "noProcessEnv": "off" } } }
    }
  ]
}
