    "fg": "#ededed",
    "fgMuted": "#8a8a8a",
    "fgFaint": "#5a5a5a",
    "lineNr": "#3a3a3a",
    "accent": "#0a84ff",
    "accentBright": "#3b9bff",
    "error": "#fb5a4b",
