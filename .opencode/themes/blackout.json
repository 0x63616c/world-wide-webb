      "dark": "kw",
      "light": "kw"
    },
    "syntaxFunction": {
      "dark": "fn",
      "light": "fn"
    },
    "syntaxVariable": {
      "dark": "var",
      "light": "var"
    },
    "syntaxString": {
      "dark": "str",
      "light": "str"
    },
    "syntaxNumber": {
      "dark": "num",
      "light": "num"
    },
    "syntaxType": {
      "dark": "type",
      "light": "type"
