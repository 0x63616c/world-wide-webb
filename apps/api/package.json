{
  "name": "@control-center/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./contract": "./src/contract/settings.ts",
    "./contract-device-settings": "./src/contract/device-settings.ts",
    "./trpc": "./src/trpc/routers/index.ts",
    "./trpc-guest": "./src/trpc/guest-router.ts",
    "./trpc-context": "./src/trpc/context.ts",
    "./trpc-init": "./src/trpc/init.ts",
    "./worker": "./src/worker-deps.ts"
  },
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:guest-smoke": "bun run scripts/guest-server-smoke.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio"
  },
  "dependencies": {
    "@www/core": "workspace:*",
    "@www/logger": "*",
    "@www/worker-runtime": "workspace:*",
    "@trpc/server": "^11.17.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.20.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
