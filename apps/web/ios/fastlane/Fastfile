default_platform(:ios)

platform :ios do
  desc "Initialize match certificates (run locally once)"
  lane :init_match do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true
    )

    match(
      type: "appstore",
      api_key: api_key,
      readonly: false
    )
  end

  desc "Build and upload to TestFlight"
  lane :release do
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true
    )

    match(
      type: "appstore",
      api_key: api_key,
      readonly: true
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "App/App.xcodeproj",
      team_id: "X9E4HG27NK",
      bundle_identifier: "co.worldwidewebb.theworkflowengine",
      profile_name: ENV["sigh_co.worldwidewebb.theworkflowengine_appstore_profile-name"],
      code_sign_identity: "Apple Distribution"
    )

    # Derive the build number from TestFlight, not the CI run number. These builds
    # already exist on the original "Evee" TestFlight app (1.0, build 48+), but
    # control-center's GitHub run_number starts from 1 — using it would collide with
    # / regress below existing builds and App Store Connect would reject the upload.
    # latest_testflight_build_number + 1 is monotonic regardless of which repo ships.
    latest = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: "co.worldwidewebb.theworkflowengine",
      initial_build_number: 48
    )
    increment_build_number(
      build_number: latest + 1,
      xcodeproj: "App/App.xcodeproj"
    )

    build_app(
      workspace: nil,
      project: "App/App.xcodeproj",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "TheWorkflowEngine.ipa",
      clean: true,
      codesigning_identity: "Apple Distribution"
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end
