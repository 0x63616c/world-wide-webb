    "@capacitor/ios": "^8.3.1",
    "@capacitor/status-bar": "^8.0.2",
    "@cc/api": "workspace:*",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@fontsource/space-mono": "^5.2.5",
    "@protomaps/basemaps": "^5.7.2",
    "@tanstack/react-query": "^5.100.8",
    "@tanstack/react-router": "^1.169.1",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "clsx": "^2.1.1",
    "maplibre-gl": "^5.24.0",
    "pmtiles": "^4.4.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
