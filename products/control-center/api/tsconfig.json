{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "types": ["bun-types"],
    // The api runs via `bun --watch src/server.ts` and never emits (root sets
    // noEmit), so the old rootDir/outDir were dead config. Dropping rootDir +
    // allowImportingTsExtensions lets modules import siblings by explicit .ts path.
    "allowImportingTsExtensions": true
  },
  "include": ["src"]
}
