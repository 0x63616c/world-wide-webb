default_platform(:ios)

platform :ios do
  desc "Initialize match certificates (run locally once)"
  lane :init_match do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true
    )

    match(
      type: "appstore",
      api_key: api_key,
      readonly: false
    )
  end

  desc "Build and upload to TestFlight"
  lane :release do
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true
    )

    # Normally readonly: CI must never mint or revoke signing assets as a side
    # effect of a routine build. But enabling/removing an App ID capability marks
    # every existing profile Invalid, and a readonly match happily installs the
    # stale cached copy , the build then succeeds while silently shipping a binary
    # without the new entitlement. (Exactly what happened when Push Notifications
    # was enabled: the profile went Invalid and the next build shipped with no
    # aps-environment.) Set MATCH_REGENERATE=true for ONE run after a capability
    # change; force: true regenerates the profile only and leaves certs alone.
    regenerate = ENV["MATCH_REGENERATE"] == "true"
    UI.important("MATCH_REGENERATE set , regenerating provisioning profile") if regenerate
    match(
      type: "appstore",
      api_key: api_key,
      readonly: !regenerate,
      force: regenerate
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "App/App.xcodeproj",
      team_id: "X9E4HG27NK",
      bundle_identifier: "co.worldwidewebb.theworkflowengine",
      profile_name: ENV["sigh_co.worldwidewebb.theworkflowengine_appstore_profile-name"],
      code_sign_identity: "Apple Distribution"
    )

    # Derive the build number from TestFlight, not the CI run number. These builds
    # already exist on the original "Evee" TestFlight app (1.0, build 48+), but
    # control-center's GitHub run_number starts from 1 , using it would collide with
    # / regress below existing builds and App Store Connect would reject the upload.
    # latest_testflight_build_number + 1 is monotonic regardless of which repo ships.
    latest = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: "co.worldwidewebb.theworkflowengine",
      initial_build_number: 48
    )
    increment_build_number(
      build_number: latest + 1,
      xcodeproj: "App/App.xcodeproj"
    )

    # Inject the CF Access service-token client id/secret as build settings so the
    # Info.plist $(CF_ACCESS_CLIENT_*) substitutions bake them into the bundle
    # (www-cuuw). Sourced from repo secrets via env in ios-build.yml; absent in a
    # local/open build, in which case the settings resolve empty and the kiosk
    # sends no Access headers (identical to today). Quoted to survive secret
    # characters; never echoed.
    access_xcargs = [
      "CF_ACCESS_CLIENT_ID='#{ENV['CF_ACCESS_KIOSK_CLIENT_ID']}'",
      "CF_ACCESS_CLIENT_SECRET='#{ENV['CF_ACCESS_KIOSK_CLIENT_SECRET']}'"
    ].join(" ")

    build_app(
      workspace: nil,
      project: "App/App.xcodeproj",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "TheWorkflowEngine.ipa",
      clean: true,
      codesigning_identity: "Apple Distribution",
      xcargs: access_xcargs
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end
