# Tiltfile - run Project Management locally.
#
#   tilt up        starts Postgres, Temporal (:7233), Temporal UI (:8233), the worker, and UI (:8791)
#   tilt down      stops the local processes
#
# Open the app at http://127.0.0.1:8791

load('ext://uibutton', 'cmd_button')

UI_PORT = 8791
TEMPORAL_PORT = 7233
TEMPORAL_UI_PORT = 8233
TEMPORAL_WORKER_HEALTH_PORT = 8792
TEMPORAL_NAMESPACE = 'project-management'
TEMPORAL_TASK_QUEUE = 'project-management'
TEMPORAL_ADDRESS = '127.0.0.1:%d' % TEMPORAL_PORT
PROJECT_MANAGEMENT_DATABASE_URL = 'postgresql://%s:%s@127.0.0.1:5433/project_management' % ('temporal', 'temporal')

PROJECT_CONFIG_DEPS = [
    'package.json',
    'tsconfig.json',
    'Tiltfile',
    '../../bun.lock',
]

PROJECT_TS_DEPS = [
    'beads-adapter.ts',
    'map.ts',
    'server.ts',
    'ticket-artifact-cleanup.ts',
    'workflow-metrics.ts',
    'workflow.ts',
    'scripts/cleanup-ticket-artifacts.ts',
    'scripts/start-temporal-dev.ts',
    'db/client.ts',
    'db/migrate.ts',
    'db/schema.ts',
    'temporal/activities.ts',
    'temporal/agent-activities.ts',
    'temporal/command-activities.ts',
    'temporal/queue-bootstrap.ts',
    'temporal/start-ticket-queue.ts',
    'temporal/state.ts',
    'temporal/worker.ts',
    'temporal/workflows.ts',
]

PROJECT_DB_DEPS = [
    'docker-compose.temporal.yml',
    'db/migrations/0001_workflow_observability.sql',
]

UI_ASSET_DEPS = [
    'public/Beads.dc.html',
    'public/support.js',
    'public/_ds',
    'public/_fonts',
    'public/media',
]

local_resource(
    'install',
    cmd='bun install --frozen-lockfile',
    deps=['package.json', '../../bun.lock'],
    labels=['setup'],
)

docker_compose('docker-compose.temporal.yml')

dc_resource(
    'postgres',
    labels=['worker'],
)

local_resource(
    'project-management-db',
    cmd='printf "%s\n" "SELECT \'CREATE DATABASE project_management\' WHERE NOT EXISTS (SELECT FROM pg_database WHERE datname = \'project_management\')\\gexec" | docker compose -f docker-compose.temporal.yml exec -T postgres psql -v ON_ERROR_STOP=1 -U temporal -d postgres',
    deps=PROJECT_DB_DEPS,
    resource_deps=['postgres'],
    labels=['worker'],
)

dc_resource(
    'temporal',
    resource_deps=['install', 'postgres'],
    labels=['worker'],
)

dc_resource(
    'temporal-ui',
    resource_deps=['temporal'],
    links=[
        link(
            'http://localhost:%d/namespaces/%s/workflows' % (TEMPORAL_UI_PORT, TEMPORAL_NAMESPACE),
            'Temporal Workflows',
        ),
    ],
    labels=['worker'],
)

local_resource(
    'temporal-ready',
    cmd='docker compose -f docker-compose.temporal.yml exec -T temporal temporal operator cluster health --address temporal:%d' % TEMPORAL_PORT,
    deps=['docker-compose.temporal.yml', 'temporal/dynamicconfig/development-sql.yaml'],
    resource_deps=['temporal'],
    labels=['worker'],
)

