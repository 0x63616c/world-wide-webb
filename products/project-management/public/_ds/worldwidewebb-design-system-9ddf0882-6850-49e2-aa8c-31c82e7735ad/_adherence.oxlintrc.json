{
  "plugins": ["react", "import"],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/controls/**",
              "components/core/**",
              "components/feedback/**",
              "ui_kits/control-center/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Space Grotesk Variable|Space Mono))/i]",
        "message": "Font not provided by the design system. Available: Space Grotesk Variable, Space Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|children|onClick|disabled|type|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, children, onClick, disabled, type, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|onClick|children|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: active, onClick, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ControlTap'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|on|sub|pending|swatch|disabled|onToggle|key|ref|className|style|children)$/]",
        "message": "<ControlTap> doesn't accept that prop. Declared props: icon, label, on, sub, pending, swatch, disabled, onToggle."
      },
      {
        "selector": "JSXOpeningElement[name.name='ControlTap'] > JSXAttribute[name.name='icon'] > Literal[value!=/^(?:lamp|bulb|fan)$/]",
        "message": "<ControlTap> icon must be one of 'lamp' | 'bulb' | 'fan'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|s|c|sw|style|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, s, c, sw, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Modal'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|onClose|title|children|width|maxHeight|key|ref|className|style|children)$/]",
        "message": "<Modal> doesn't accept that prop. Declared props: open, onClose, title, children, width, maxHeight."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|style|key|ref|className|style|children)$/]",
        "message": "<Pill> doesn't accept that prop. Declared props: tone, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Skeleton'] > JSXAttribute > JSXIdentifier[name!=/^(?:w|h|borderRadius|key|ref|className|style|children)$/]",
        "message": "<Skeleton> doesn't accept that prop. Declared props: w, h, borderRadius."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|accent|muted|sub|key|ref|className|style|children)$/]",
        "message": "<Stat> doesn't accept that prop. Declared props: label, value, accent, muted, sub."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute > JSXIdentifier[name!=/^(?:online|key|ref|className|style|children)$/]",
        "message": "<StatusDot> doesn't accept that prop. Declared props: online."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:on|onToggle|disabled|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: on, onToggle, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tile'] > JSXAttribute > JSXIdentifier[name!=/^(?:padding|children|className|style|onClick|key|ref|className|style|children)$/]",
        "message": "<Tile> doesn't accept that prop. Declared props: padding, children, className, style, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='TileHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|right|iconSize|titleSize|key|ref|className|style|children)$/]",
        "message": "<TileHeader> doesn't accept that prop. Declared props: icon, title, right, iconSize, titleSize."
      }
    ]
  },
  "overrides": [
    {
      "files": ["**/index.js"],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
