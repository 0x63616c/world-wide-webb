{
  "name": "project-management",
  "private": true,
  "type": "module",
  "description": "Live web UI for this project's beads issues (Claude Design prototype wired to bd).",
  "scripts": {
    "start": "bun run server.ts",
    "dev": "bun run server.ts",
    "dev:temporal": "bun run scripts/start-temporal-dev.ts",
    "temporal:server": "temporal server start-dev --namespace project-management",
    "worker:temporal": "bun run temporal/worker.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@temporalio/activity": "^1.13.2",
    "@temporalio/client": "^1.13.2",
    "@temporalio/worker": "^1.13.2",
    "@temporalio/workflow": "^1.13.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
