{
  "name": "project-management",
  "private": true,
  "type": "module",
  "description": "Live web UI for this project's beads issues (Claude Design prototype wired to bd).",
  "scripts": {
    "start": "bun run server.ts",
    "dev": "bun --watch server.ts",
    "dev:temporal": "bun run scripts/start-temporal-dev.ts",
    "temporal:server": "docker compose -f docker-compose.temporal.yml up temporal temporal-ui",
    "temporal:reset": "docker compose -f docker-compose.temporal.yml down --volumes --remove-orphans",
    "queue:temporal": "bun run temporal/start-ticket-queue.ts",
    "worker:temporal": "bun temporal/worker.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@temporalio/activity": "^1.13.2",
    "@temporalio/client": "^1.13.2",
    "@temporalio/worker": "^1.13.2",
    "@temporalio/workflow": "^1.13.2",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/pg": "^8.20.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
