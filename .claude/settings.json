{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/guard-bun-test.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Read(secrets/**)",
      "Bash(sops -d*)",
      "Bash(sops --decrypt*)",
      "Bash(cat secrets/*)",
      "Bash(sops decrypt*)"
    ]
  }
}
