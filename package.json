{
  "name": "world-wide-webb",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "products/control-center/*",
    "products/*",
    "packages/*",
    "products/*/apps/*",
    "products/*/packages/*",
    "infra",
    "infra/unifi",
    "infra/cloudflare"
  ],
  "scripts": {
    "dev": "bun run --filter @product/control-center dev",
    "test": "vitest run",
    "test:dockerfile-manifests": "bun scripts/check-dockerfile-manifests.ts",
    "test:product-workspaces": "bun scripts/check-product-workspaces.ts",
    "test:control-center-ci-split": "bun scripts/check-control-center-ci-split.ts",
    "test:product-ci-isolation": "bun scripts/check-product-ci-isolation.ts",
    "test:tilt-product-lanes": "bun scripts/check-tilt-product-lanes.ts",
    "test:product-doc-paths": "bun scripts/check-product-doc-paths.ts",
    "test:coverage": "bash scripts/coverage.sh",
    "identity:audit": "scripts/check-rename-identity.py",
    "badges": "bun scripts/gen-badges.ts",
    "measure:ci": "bun scripts/measure-ci-latency.ts",
    "check:control-center-product-boundary": "bun scripts/check-control-center-product-boundary.ts",
    "format": "bun scripts/quality-gate.ts format",
    "lint": "bun scripts/quality-gate.ts lint",
    "lint:tracked": "bun scripts/quality-gate.ts lint-tracked",
    "lint:fix": "bun run format",
    "gate": "bun scripts/quality-gate.ts gate",
    "gate:pre-push": "bun scripts/quality-gate.ts pre-push",
    "knip": "bun scripts/quality-gate.ts knip",
    "knip:fix": "bunx knip --fix --allow-remove-files",
    "typecheck": "bun run --filter '*' typecheck && bun run typecheck:config",
    "typecheck:config": "tsc -p tsconfig.config.json --noEmit",
    "prepare": "bunx lefthook install --force"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@www/platform": "workspace:*",
    "@vitest/coverage-v8": "^3.2.4",
    "knip": "^6.16.1",
    "lefthook": "^2.1.9",
    "playwright": "^1.60.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "esbuild",
    "lefthook"
  ],
  "dependencies": {
    "bdui": "^0.0.38"
  }
}
