{
  "name": "control-center",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "products/control-center/*",
    "products/*",
    "!products/project-management",
    "packages/*",
    "products/*/apps/*",
    "products/*/packages/*",
    "infra",
    "infra/unifi",
    "infra/cloudflare"
  ],
  "scripts": {
    "dev": "tilt up",
    "test": "vitest run",
    "test:product-workspaces": "bun scripts/check-product-workspaces.ts",
    "test:control-center-ci-split": "bun scripts/check-control-center-ci-split.ts",
    "test:product-ci-isolation": "bun scripts/check-product-ci-isolation.ts",
    "test:tilt-product-lanes": "bun scripts/check-tilt-product-lanes.ts",
    "test:product-doc-paths": "bun scripts/check-product-doc-paths.ts",
    "test:amp-ci-deploy": "bun scripts/check-amp-ci-deploy.ts",
    "test:coverage": "bash scripts/coverage.sh",
    "identity:audit": "scripts/check-rename-identity.py",
    "badges": "bun scripts/gen-badges.ts",
    "check:control-center-product-boundary": "bun scripts/check-control-center-product-boundary.ts",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --write .",
    "knip": "bunx knip",
    "knip:fix": "bunx knip --fix --allow-remove-files",
    "typecheck": "bun run --filter '*' typecheck && bun run typecheck:config",
    "typecheck:config": "tsc -p tsconfig.config.json --noEmit",
    "prepare": "bunx lefthook install --force"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@repo/platform": "workspace:*",
    "@vitest/coverage-v8": "^3.2.4",
    "knip": "^6.16.1",
    "lefthook": "^2.1.9",
    "playwright": "^1.60.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "esbuild",
    "lefthook"
  ],
  "dependencies": {
    "bdui": "^0.0.38"
  }
}
