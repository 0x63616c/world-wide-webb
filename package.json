{
  "name": "control-center",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "tilt up",
    "bosun": "bun packages/bosun/src/cli.ts",
    "test": "vitest run",
    "test:coverage": "bash scripts/coverage.sh",
    "badges": "bun scripts/gen-badges.ts",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --write .",
    "typecheck": "bun run --filter '*' typecheck && bun run typecheck:config",
    "typecheck:config": "tsc -p tsconfig.config.json --noEmit",
    "prepare": "bunx lefthook install --force"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@vitest/coverage-v8": "^3.2.4",
    "lefthook": "^2.1.9",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "esbuild",
    "lefthook"
  ]
}
